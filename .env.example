# Spyglass Environment Configuration
# Copy this file to .env and customize for your setup

# SSH user for terminal access (must match the user whose SSH key is mounted)
SSH_USER=your_username

# Path to SSH private key (will be mounted read-only into container)
SSH_KEY_PATH=/home/your_username/.ssh/id_ed25519

# Domain for Traefik routing
DOMAIN=spyglass.yourdomain.com

# Session secret (required in production). Generate with: openssl rand -hex 32
SESSION_SECRET=
